{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/resultados/layout,_N_T_/resultados/page,_N_T_/resultados"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/resultados/__PAGE__",
    "/resultados",
    "/_index",
    "/_head"
  ]
}